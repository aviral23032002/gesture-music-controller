# -------------------------------------------------------------------
# Root-level exclusions to keep repository clean and focused
# We only want to track 8-gesture-controller/ and the ESP32 files.
# -------------------------------------------------------------------

# Ignore old root Python scripts
/*.py

# Ignore old root data and model folders
/data/
/data_og/
/data_og_2/
/model/

# Ignore presentation and temporary root files
*.key
create_zip.sh
dependencies.lock
pins.txt

# -------------------------------------------------------------------
# Standard project ignores below
# -------------------------------------------------------------------

# Build directories
build/
esp-idf/
managed_components/

# ESP-IDF specific
sdkconfig.old
*.log

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs and temporary files
log/
*.tmp
*.temp